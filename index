      const mainPage = document.getElementById("mainPage");
      const summaryPage = document.getElementById("summaryPage");
      const showSummary = view === "summary";
      mainPage.classList.toggle("active", !showSummary);
      summaryPage.classList.toggle("active", showSummary);
      if ((showSummary && location.hash !== "#summary-sheet") || (!showSummary && location.hash !== "#main")) {
        history.replaceState(null, "", showSummary ? "#summary-sheet" : "#main");
      }
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
    function bindNavigation() {
      const openBtn = document.getElementById("openSummaryPage");
      const backBtn = document.getElementById("backToMainBtn");
      openBtn.addEventListener("click", () => setView("summary"));
      openBtn.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          setView("summary");
        }
      });
      backBtn.addEventListener("click", () => setView("main"));
      window.addEventListener("hashchange", () => {
        setView(location.hash === "#summary-sheet" ? "summary" : "main");
      });
    }
    function renderThemeBars(containerId, counts, order) {
      const container = document.getElementById(containerId);
      const maxValue = Math.max(...order.map(key => counts[key] || 0), 1);
      container.innerHTML = order.map(key => {
        const value = counts[key] || 0;
        const width = (value / maxValue) * 100;
        return `
          <div class="bar-row">
            <div class="bar-label">${escapeHtml(key)}</div>
            <div class="bar-track"><div class="bar-fill" style="width:${width}%"></div></div>
            <div class="bar-value">${value}</div>
          </div>
        `;
      }).join("");
    }
    function renderCommentSection(topId, allId, topItems, allItems) {
      const topBox = document.getElementById(topId);
      const allBox = document.getElementById(allId);
      if (!allItems || allItems.length === 0) {
        topBox.innerHTML = "";
        allBox.innerHTML = '<div class="empty">수집된 의견이 없습니다.</div>';
        return;
      }
      topBox.innerHTML = (topItems && topItems.length ? topItems : allItems.slice(0,3)).map(text => `
        <div class="comment-pill">${escapeHtml(text)}</div>
      `).join("");
      allBox.innerHTML = allItems.map(text => `
        <div class="comment-item">${escapeHtml(text)}</div>
      `).join("");
    }
    function renderOverallThemeChips(containerId, counts, order) {
      const container = document.getElementById(containerId);
      const sorted = [...order].sort((a,b) => (counts[b] || 0) - (counts[a] || 0)).filter(key => (counts[key] || 0) > 0);
      container.innerHTML = sorted.slice(0,5).map(key => `
        <div class="theme-chip"><span>${escapeHtml(key)}</span><span>${formatNumber(counts[key] || 0)}건</span></div>
      `).join("");
    }
    function renderTop10() {
      const tbody = document.getElementById("top10Body");
      tbody.innerHTML = DATA.top10.map((item, idx) => `
        <tr>
          <td class="rank">${idx + 1}</td>
          <td>${escapeHtml(item.deptName)}</td>
          <td class="num">${formatNumber(item.operationCount)}</td>
          <td class="num">${formatNumber(item.studentCount)}</td>
        </tr>
      `).join("");
    }
    function getSummaryRows() {
      return Array.from(document.querySelectorAll("#summaryTableBody tr")).map(row => ({
        row,
        operationType: row.children[1]?.textContent.trim() || "",
        month: row.children[2]?.textContent.trim() || "",
        region: row.children[6]?.textContent.trim() || "",
        gender: row.children[7]?.textContent.trim() || "",
        schoolType: row.children[8]?.textContent.trim() || "",
        category: row.children[11]?.textContent.trim() || ""
      }));
    }
    function fillFilterOptions(selectId, values, numeric = false) {
      const select = document.getElementById(selectId);
      const uniqueValues = [...new Set(values.filter(Boolean))].sort((a, b) => {
        if (numeric) return Number(a) - Number(b);
        return a.localeCompare(b, "ko");
      });
      select.innerHTML = '<option value="">전체</option>' + uniqueValues.map(value => `<option value="${escapeHtml(value)}">${escapeHtml(value)}</option>`).join("");
    }
    function applySummaryFilters() {
      const filters = {
        operationType: document.getElementById("filterOperationType").value,
        month: document.getElementById("filterMonth").value,
        region: document.getElementById("filterRegion").value,
        gender: document.getElementById("filterGender").value,
        schoolType: document.getElementById("filterSchoolType").value,
        category: document.getElementById("filterCategory").value
      };
      getSummaryRows().forEach(item => {
        const visible = Object.entries(filters).every(([key, value]) => !value || item[key] === value);
        item.row.style.display = visible ? "" : "none";
      });
    }
    function bindSummaryFilters() {
      const rows = getSummaryRows();
      fillFilterOptions("filterOperationType", rows.map(item => item.operationType));
      fillFilterOptions("filterMonth", rows.map(item => item.month), true);
      fillFilterOptions("filterRegion", rows.map(item => item.region));
      fillFilterOptions("filterGender", rows.map(item => item.gender));
      fillFilterOptions("filterSchoolType", rows.map(item => item.schoolType));
      fillFilterOptions("filterCategory", rows.map(item => item.category));
      ["filterOperationType", "filterMonth", "filterRegion", "filterGender", "filterSchoolType", "filterCategory"].forEach(id => {
        document.getElementById(id).addEventListener("change", applySummaryFilters);
      });
      document.getElementById("resetSummaryFilters").addEventListener("click", () => {
        ["filterOperationType", "filterMonth", "filterRegion", "filterGender", "filterSchoolType", "filterCategory"].forEach(id => {
          document.getElementById(id).value = "";
        });
        applySummaryFilters();
      });
    }
    function updateDepartment(deptNorm) {
      const dept = DATA.departments.find(item => item.deptNorm === deptNorm) || DATA.departments[0];
      const opAvg = DATA.averages.operationCount;
      const stAvg = DATA.averages.studentCount;
      const opRatio = dept.operationCount / opAvg;
      const stRatio = dept.studentCount / stAvg;

      document.getElementById("bestSummary").textContent = dept.bestSummary;
      document.getElementById("needSummary").textContent = dept.needSummary;
      document.getElementById("operationCount").textContent = formatNumber(dept.operationCount);
      document.getElementById("studentCount").textContent = formatNumber(dept.studentCount);
      document.getElementById("operationMeta").textContent = `전체 학과 평균 ${opAvg.toLocaleString("ko-KR", {minimumFractionDigits: 1, maximumFractionDigits: 1})}회 대비 ${compareLabel(opRatio)} · 강좌 ${formatNumber(dept.lectureCount)}개`;
      document.getElementById("studentMeta").textContent = `전체 학과 평균 ${stAvg.toLocaleString("ko-KR", {minimumFractionDigits: 1, maximumFractionDigits: 1})}명 대비 ${compareLabel(stRatio)}`;
      document.getElementById("studentCompareText").textContent = `평균 대비 ${Math.round(stRatio * 100)}%`;
      document.getElementById("operationCompareText").textContent = `평균 대비 ${Math.round(opRatio * 100)}%`;
      document.getElementById("studentCompareFill").style.width = `${compareBarWidth(stRatio)}%`;
      document.getElementById("operationCompareFill").style.width = `${compareBarWidth(opRatio)}%`;
      renderThemeBars("positiveThemeBars", dept.positiveThemeCounts, POSITIVE_ORDER);
      renderThemeBars("negativeThemeBars", dept.negativeThemeCounts, NEGATIVE_ORDER);
      document.getElementById("actionPoint").textContent = dept.actionPoint;
      document.getElementById("positiveCountText").textContent = `전체 만족 의견 ${formatNumber(dept.positiveCount)}건`;
      document.getElementById("negativeCountText").textContent = `전체 아쉬움 의견 ${formatNumber(dept.negativeCount)}건`;
      renderCommentSection("topPositiveComments", "allPositiveComments", dept.topPositiveComments, dept.allPositiveComments);
      renderCommentSection("topNegativeComments", "allNegativeComments", dept.topNegativeComments, dept.allNegativeComments);
    }
    function init() {
      const select = document.getElementById("deptSelect");
      select.innerHTML = DATA.departments.map(item => `<option value="${escapeHtml(item.deptNorm)}">${escapeHtml(item.deptName)}</option>`).join("");
      select.value = DATA.defaultDept;
      select.addEventListener("change", (e) => updateDepartment(e.target.value));
      bindNavigation();
      bindSummaryFilters();
      renderTop10();
      renderOverallThemeChips("overallPositiveThemes", DATA.overallPositiveThemes, POSITIVE_ORDER);
      renderOverallThemeChips("overallNegativeThemes", DATA.overallNegativeThemes, NEGATIVE_ORDER);
      updateDepartment(DATA.defaultDept);
      setView(location.hash === "#summary-sheet" ? "summary" : "main");
    }
    init();
  </script>
</body>
</html>
